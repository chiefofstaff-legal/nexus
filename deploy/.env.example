# NEXUS POC — required runtime environment variables.
# Copy to deploy/.env and fill in the real values; never commit deploy/.env.

# --- LLM providers ---
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# --- Persistence ---
# Defaults to /data/persistence.sqlite inside the backend container.
NEXUS_PERSISTENCE_DB=/data/persistence.sqlite
NEXUS_INGESTION_COST_LOG=/data/ingestion-costs.jsonl

# --- MS Graph (W6 email + calendar) ---
# Create an Azure AD app registration; grant Mail.Send and Calendars.ReadWrite
# application permissions; record the values below. See docs/operational-runbook.md.
MS_GRAPH_TENANT_ID=00000000-0000-0000-0000-000000000000
MS_GRAPH_CLIENT_ID=00000000-0000-0000-0000-000000000000
MS_GRAPH_CLIENT_SECRET=replace-me
MS_GRAPH_USER_EMAIL=mailbox@your-firm.example

# --- Optional: Ollama base URL ---
# Defaults to http://ollama:11434 inside the docker network.
OLLAMA_BASE_URL=http://ollama:11434

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://nexus-backend:8000
