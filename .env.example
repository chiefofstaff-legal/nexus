# NEXUS POC Environment Variables
# Copy to .env at the project root and fill in values.

# ── LLM providers (read directly by the SDK clients) ────────────────
# Public / internal routing (free tier, Groq SDK reads this directly)
GROQ_API_KEY=gsk_...

# Complex-reasoning + confidential fallback (Anthropic SDK reads this directly)
ANTHROPIC_API_KEY=sk-ant-...

# ── On-prem confidential path (DISABLED by default) ─────────────────
# Set NEXUS_OLLAMA_ENABLED=true in local dev with a GPU or ≥6 GB RAM to
# route CONFIDENTIAL sensitivity to a local Ollama model. Leave unset
# (or false) on prod — the shared VPS cannot run on-prem inference.
NEXUS_OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
NEXUS_OLLAMA_MODEL=gemma4:e4b
